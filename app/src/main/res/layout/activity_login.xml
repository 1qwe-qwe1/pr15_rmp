<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_green"
    tools:context=".LoginActivity">


    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/register"
        android:textColor="@color/white"
        android:textSize="70px"
        tools:layout_editor_absoluteX="45dp"
        tools:layout_editor_absoluteY="562dp" />

    <Button
        android:id="@+id/button2"
        android:layout_width="321dp"
        android:layout_height="61dp"
        android:backgroundTint="@color/light_green"
        android:text="@string/sign"
        android:textSize="60px"
        app:cornerRadius="15dp"
        tools:layout_editor_absoluteX="45dp"
        tools:layout_editor_absoluteY="459dp" />

    <Button
        android:id="@+id/button3"
        android:layout_width="321dp"
        android:layout_height="61dp"
        android:backgroundTint="@color/light_green"
        android:text="@string/profile"
        android:textSize="60px"
        app:cornerRadius="15dp"
        tools:layout_editor_absoluteX="46dp"
        tools:layout_editor_absoluteY="628dp" />

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="278dp"
        android:layout_height="565dp"
        app:srcCompat="@drawable/logo_mini"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="-153dp" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="174dp"
        android:layout_height="45dp"
        android:text="@string/sign"
        android:textColor="@color/white"
        android:textSize="100px"
        tools:layout_editor_absoluteX="38dp"
        tools:layout_editor_absoluteY="165dp" />

    <EditText
        android:id="@+id/editTextTextEmailAddress"
        android:layout_width="321dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/light_green2"
        android:ems="10"
        android:inputType="textEmailAddress"
        android:textColor="@color/light_green2"
        android:textColorHint="@color/light_green2"
        tools:layout_editor_absoluteX="45dp"
        tools:layout_editor_absoluteY="295dp"
        android:hint="@string/email"
        android:paddingStart="20dp"
        android:paddingBottom="20dp"/>

    <EditText
        android:id="@+id/editTextTextPassword"
        android:layout_width="321dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="@string/password"
        android:textColorHint="@color/light_green2"
        android:textColor="@color/light_green2"
        android:backgroundTint="@color/light_green2"
        android:inputType="textPassword"
        tools:layout_editor_absoluteX="46dp"
        tools:layout_editor_absoluteY="368dp"
        android:paddingStart="20dp"
        android:paddingBottom="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>